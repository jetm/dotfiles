#!/bin/bash

set -e

PLATFORM=${1:-ridley}
MOD=${2:-mac-mgmt}

HALON_PATH=/ws/tiamarin/halon
comp_comm=compile_commands.json
mod_comp_comm=${HALON_PATH}/halon-src/${MOD}/${comp_comm}
HALON_MOD_PATH=${HALON_PATH}/build-${PLATFORM}/tmp/work/${PLATFORM}-cnos-linux/${MOD}/1.0-r0_${PLATFORM}

# build-peloton/tmp/work/core2-64-cnos-linux/hpe-switchd-rosewood-plugin/1.0-r0_peloton/halon-src/hpe-switchd-rosewood-plugin/compile_commands.json
# build-speedway/tmp/work/speedway-cnos-linux/hpe-switchd-rosewood-plugin/1.0-r0_speedway/halon-src/hpe-switchd-rosewood-plugin/compile_commands.json

# remove ${MOD} build path
echo "Generate ${mod_comp_comm} from ${HALON_MOD_PATH}/halon-src/${comp_comm}"
cp --force ${HALON_MOD_PATH}/halon-src/${MOD}/${comp_comm} ${mod_comp_comm}
# perl -pi -e "s#${HALON_MOD_PATH}#${HALON_PATH}#g if $. > 6" ${mod_comp_comm}
sed --in-place "s#${HALON_MOD_PATH}/#${HALON_PATH}/#g" ${mod_comp_comm}
