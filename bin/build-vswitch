#!/bin/bash
#
# Brief description here
#
# Usage:
#
#  LOG_LEVEL=7 ./build-halon -p ${PLATFORM}
#

# Global variables
START=$(date --iso-8601=seconds)
export START

START_DATE=$(date)

__HALON_REPO=/ws/tiamarin/halon-opengrok
GIT="git -C ${__HALON_REPO}"

#
# START Functions
#

check-param() {
  local param="$1"
  shift
  local msg="$*"
  if [ -z "${param}" ]; then
    echo >&2 "error: ${msg}"
    return 1
  fi
  return 0
}

env_halon() {
  export web_proxy=http://web-proxy.rose.hpecorp.net:8088
  export http_proxy=http://web-proxy.rose.hpecorp.net:8088
  export ftp_proxy=http://web-proxy.houston.hpecorp.net:8080
  export https_proxy=http://web-proxy.rose.hpecorp.net:8088
  export no_proxy=localhost,127.0.0.1,localhost6,::1,.localdomain,.hpecorp.net

  export _=/usr/bin/env

  export HPE_REPO_DIR="${__HALON_REPO}"
  export HPE_PRE_REPO_PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/pnb/software/attools/bin/Python3.4.3/bin:/pnb/software/attools/bin/ActivePython-2.7/bin:/aruba/halon/infra:/aruba/halon/tools:/aruba/halon/infra/ntl_tools:/tools/halon:/tools

  export SSTATE_DIR=/ws/tiamarin/cache/sstate
  export DL_DIR=/ws/tiamarin/cache/downloads
}

do-copy-vswitch-files() {
  local PLATFORM=${1}
  local OG_PATH=${2}
  PLATFORM_BUILD_PATH="${HPE_REPO_DIR}"/build-"${PLATFORM}"/tmp/work/core2-64-cnos-linux
  OPENVSWITCH_DIR="${PLATFORM_BUILD_PATH}"/ops-openvswitch/1.0-r0/halon-src/ops-openvswitch/lib

  # Index all branches undder HALON_OPENGROK_DIR
  info "Updating vswitch generated files for ${PLATFORM} and ${br}"
  # Copy generated files
  cp --update --verbose \
    "${OPENVSWITCH_DIR}"/vswitch-idl.[ch] \
    "${PLATFORM_BUILD_PATH}"/../../sysroots/"${PLATFORM}"/usr/include/vswitch_empty_values.h \
    "${OG_PATH}"
}

do-ops-openvswitch() {
  local PLATFORM=${1}

  OG_VSWITCH_PATH="/users/tiamarin/public_html/opengrok/src"
  HALON_PREFIX="${OG_VSWITCH_PATH}/HALON_"
  HALON_SUFFIX="VSWITCH_DIR"

  declare -A HALON_BRANCHES
  HALON_BRANCHES[master]="${HALON_PREFIX}master/${HALON_SUFFIX}"
  HALON_BRANCHES[rel/10_02]="${HALON_PREFIX}release_10.02/${HALON_SUFFIX}"
  HALON_BRANCHES[rel/10_03]="${HALON_PREFIX}release_10.03/${HALON_SUFFIX}"
  HALON_BRANCHES[rel/10_04]="${HALON_PREFIX}release_10.04/${HALON_SUFFIX}"
  HALON_BRANCHES[rel/10_04_0001]="${HALON_PREFIX}release_10.04.0001/${HALON_SUFFIX}"

  # set -x
  for br in "${!HALON_BRANCHES[@]}"; do
    info "Changing to branch ${br}"
    ${GIT} checkout ${br}
    info

    info "Updating branch ${br}"
    ${GIT} pull origin "${br}"
    info

    info "Start building ops-openvswitch in ${PLATFORM} and ${br}"
    hb task -p "${PLATFORM}" -m ops-openvswitch install
    info "End building ops-openvswitch in ${PLATFORM} and ${br}"
    info

    info "Copy vswitch files from ${PLATFORM} and ${br}"
    do-copy-vswitch-files "${PLATFORM}" "${HALON_BRANCHES[$br]}"
    info
  done
}

ubc() {
  check-param "${1}" "missing platform name"
  local PLATFORM=${1}
  env_halon

  # Go to HALON repo for src
  info "Going to ${__HALON_REPO}"
  cd "${__HALON_REPO}"

  # info "Removing build-${PLATFORM}"
  # rm -rf build-"${PLATFORM}"

  # Build disk image platform
  do-ops-openvswitch "${PLATFORM}"
  echo
}

vswitch_main() {
  local PLATFORM=${1}
  ubc "${PLATFORM}"
}

#
# END Functions
#

#
# Main
#
source build-vswitch-main.sh

### Validation
# Error out if the things required for your script are not present
#
[[ "${arg_p:-}" ]] || \
  help "Setting a platform with -p or --platform is required"
PLATFORM="${arg_p}"

[[ "${LOG_LEVEL:-}" ]] || \
  emergency "Cannot continue without LOG_LEVEL."

FILE_SIGN="/tmp/cron_${PLATFORM}.err"
export FILE_SIGN

# shellcheck disable=SC2154
[ -f "${FILE_SIGN}" ] && \
  emergency "error: ${__base} is locked. Remove ${FILE_SIGN} before run"


echo "START BUILD ${PLATFORM} at ${START_DATE}"
echo

vswitch_main "${PLATFORM}"

#
# END Main
#

# vim:set ts=2 sw=2 et:
